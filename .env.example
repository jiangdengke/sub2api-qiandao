PORT=8787
PUBLIC_BASE_PATH=/checkin

# Sub2API address reachable from this service.
SUB2API_BASE_URL=http://127.0.0.1:3000
SUB2API_AUTH_ME_PATH=/api/v1/auth/me

# Keep this value server-side only.
SUB2API_ADMIN_API_KEY=replace-with-sub2api-admin-api-key
SUB2API_ADMIN_AUTH_HEADER=x-api-key
SUB2API_ADMIN_AUTH_VALUE=

# Balance top-up endpoint. {id} will be replaced by the current Sub2API user id.
SUB2API_BALANCE_PATH_TEMPLATE=/api/v1/admin/users/{id}/balance
SUB2API_BALANCE_OPERATION=add
SUB2API_BALANCE_AMOUNT_FIELD=balance

CHECKIN_AMOUNT=0.1
CHECKIN_UNIT=USD
CHECKIN_TIMEZONE=Asia/Shanghai
CHECKIN_NOTE_PREFIX=Daily check-in

# Optional admin page. Visit /checkin/admin/ after reverse proxying.
CHECKIN_ADMIN_PASSWORD=change-this-password

# Optional initial weighted reward rules. Format:
# amount:weight:label,amount:weight:label
# Example below means 0.05 has 80% weight, 0.1 has 15%, 1 has 5%.
# CHECKIN_REWARD_RULES=0.05:80:Small,0.1:15:Normal,1:5:Lucky

DATA_FILE=./data/checkins.json

# Extra localStorage keys the iframe should inspect when it is served from
# the same origin as Sub2API.
PUBLIC_TOKEN_STORAGE_KEYS=token,access_token,auth_token,sub2api_token,auth-storage,user,sub2api-auth
