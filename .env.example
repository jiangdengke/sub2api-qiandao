# 签到服务监听端口。Docker 默认映射 8787:8787。
PORT=8787

# 对外访问路径。反代到 Sub2API 同源时推荐使用 /checkin。
PUBLIC_BASE_PATH=/checkin

# 签到服务访问 Sub2API 后端的地址。
# 本机直接运行 Sub2API 时可用：http://127.0.0.1:3000
# 和 Sub2API 放在同一个 docker compose 网络时通常用：http://sub2api:3000
SUB2API_BASE_URL=http://127.0.0.1:3000

# Sub2API 当前登录用户接口，用于确认是谁在签到。
SUB2API_AUTH_ME_PATH=/api/v1/auth/me

# Sub2API 管理员 API Key。只会保存在服务端，不能暴露到浏览器。
SUB2API_ADMIN_API_KEY=replace-with-sub2api-admin-api-key

# 调用 Sub2API 管理接口时使用的鉴权 header。
# 默认 Sub2API 使用 x-api-key。如果你的实例要求 Authorization，可改为 Authorization。
SUB2API_ADMIN_AUTH_HEADER=x-api-key

# 自定义完整鉴权值。留空时会自动使用 SUB2API_ADMIN_API_KEY。
# 如果 SUB2API_ADMIN_AUTH_HEADER=Authorization，可填：Bearer your-admin-api-key
SUB2API_ADMIN_AUTH_VALUE=

# Sub2API 用户余额调整接口。{id} 会替换为当前签到用户 ID。
SUB2API_BALANCE_PATH_TEMPLATE=/api/v1/admin/users/{id}/balance

# 余额操作方式：add 表示增加余额。
SUB2API_BALANCE_OPERATION=add

# 余额金额字段名。当前 Sub2API 默认是 balance。
SUB2API_BALANCE_AMOUNT_FIELD=balance

# 固定签到金额。没有配置随机奖励规则时，会使用这个金额。
CHECKIN_AMOUNT=0.1

# 奖励单位，仅用于页面展示和日志，不影响 Sub2API 的实际数值字段。
CHECKIN_UNIT=USD

# 判断“今天是否已签到”的时区。
CHECKIN_TIMEZONE=Asia/Shanghai

# 初始余额备注前缀。首次启动会写入 SQLite；之后可在 /checkin/admin/ 管理端修改。
CHECKIN_NOTE_PREFIX=Daily check-in

# 签到管理端密码。访问 /checkin/admin/ 时只需要输入这个密码，不需要用户名。
CHECKIN_ADMIN_PASSWORD=change-this-password

# 可选：初始随机奖励规则。首次启动会写入 SQLite；之后金额、权重、名称都可在管理端修改。
# 格式：金额:权重:名称,金额:权重:名称
# 示例表示 0.05 权重 80、0.1 权重 15、1 权重 5，也就是约 80%、15%、5%。
# 推荐先通过 /checkin/admin/ 管理端配置；这里通常保持注释即可。
# CHECKIN_REWARD_RULES=0.05:80:Small,0.1:15:Normal,1:5:Lucky

# SQLite 数据库文件。SQLite 不需要单独启动数据库服务。
# Docker 部署时挂载 ./data:/app/data 后，这个文件会持久化到宿主机 ./data/checkins.db。
CHECKIN_DB_FILE=./data/checkins.db

# 旧版 JSON 数据文件路径。如果这个文件存在且 SQLite 为空，服务启动时会自动迁移一次。
DATA_FILE=./data/checkins.json

# iframe 与 Sub2API 同源时，用于尝试读取登录 token 的 localStorage key 列表。
# 正常情况下无需修改；如果你的 Sub2API 前端 token key 不同，再追加到这里。
PUBLIC_TOKEN_STORAGE_KEYS=token,access_token,auth_token,sub2api_token,auth-storage,user,sub2api-auth
