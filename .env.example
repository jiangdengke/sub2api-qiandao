# 服务监听端口。docker-compose.yml 默认把宿主机 8787 映射到容器 8787。
PORT=8787

# 对外访问路径。反代到 https://你的域名/checkin/ 时保持 /checkin。
PUBLIC_BASE_PATH=/checkin

# Sub2API 地址。
# 如果 qiandao 和 Sub2API 在同一个 Docker Compose 网络，可用 http://sub2api:3000。
# 如果 qiandao 在 Docker，Sub2API/Caddy/Nginx 在宿主机，可用 http://host.docker.internal:18080。
SUB2API_BASE_URL=http://host.docker.internal:18080
SUB2API_AUTH_ME_PATH=/api/v1/auth/me

# Sub2API 管理员 API Key。只保存在服务端，不会暴露给浏览器。
SUB2API_ADMIN_API_KEY=change-this-admin-api-key
SUB2API_ADMIN_AUTH_HEADER=x-api-key
SUB2API_ADMIN_AUTH_VALUE=

# Sub2API 余额增加接口。大多数情况保持默认即可。
SUB2API_BALANCE_PATH_TEMPLATE=/api/v1/admin/users/{id}/balance
SUB2API_BALANCE_OPERATION=add
SUB2API_BALANCE_AMOUNT_FIELD=balance

# 签到基础配置。
CHECKIN_UNIT=USD
CHECKIN_TIMEZONE=Asia/Shanghai
CHECKIN_ADMIN_PASSWORD=change-this-password
CHECKIN_DB_FILE=./data/checkins.db
CHECKIN_NOTE_PREFIX=Daily check-in

# 推荐：仿 New API 的区间随机。用户页不会公开范围，签到后才显示实际金额。
CHECKIN_REWARD_MODE=range_random
CHECKIN_MIN_AMOUNT=0.1
CHECKIN_MAX_AMOUNT=2
CHECKIN_AMOUNT_STEP=0.1

# 可选：权重档位随机。启用时把 CHECKIN_REWARD_MODE 改成 weighted_random。
# CHECKIN_REWARD_MODE=weighted_random
# CHECKIN_REWARD_RULES=0.05:80:Small,0.1:15:Normal,1:5:Lucky

# 旧版 JSON 数据文件路径。如果文件存在且 SQLite 为空，服务启动时会自动迁移一次。
DATA_FILE=./data/checkins.json

# iframe 与 Sub2API 同源时，尝试读取登录 token 的 localStorage key 列表。
# 正常情况下无需修改；如果你的 Sub2API 前端 token key 不同，再追加到这里。
PUBLIC_TOKEN_STORAGE_KEYS=token,access_token,auth_token,sub2api_token,auth-storage,user,sub2api-auth
