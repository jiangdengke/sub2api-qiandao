{
  "name": "sub2api-qiandao",
  "version": "0.1.0",
  "description": "A small daily check-in service for Sub2API custom iframe tabs.",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node src/server.js",
    "start:env": "node --env-file=.env src/server.js",
    "dev": "node --watch src/server.js",
    "check": "node --check src/server.js && node --check public/app.js"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
